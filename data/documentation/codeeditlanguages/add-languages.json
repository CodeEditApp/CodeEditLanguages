pe":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Now you need to create the Swift bindings which are a "},{"type":"codeVoice","code":"header"},{"type":"text","text":" file exposing the "},{"type":"codeVoice","code":"tree_sitter_{lang}()"},{"text":" function.","type":"text"}]},{"inlineContent":[{"text":"First of all create the following directories inside the ","type":"text"},{"type":"codeVoice","code":"bindings\/"},{"text":" directory:","type":"text"}],"type":"paragraph"},{"type":"paragraph","inlineContent":[{"type":"codeVoice","code":".\/bindings\/swift\/TreeSitter{LANG}\/"}]},{"type":"paragraph","inlineContent":[{"text":"Inside that folder create a new header file called ","type":"text"},{"code":"{lang}.h","type":"codeVoice"},{"type":"text","text":"."}]},{"type":"codeListing","code":["#ifndef TREE_SITTER_{LANG}_H_","#define TREE_SITTER_{LANG}_H_","","typedef struct TSLanguage TSLanguage;","","#ifdef __cplusplus","extern \"C\" {","#endif","","extern TSLanguage *tree_sitter_{lang}();","","#ifdef __cplusplus","}","#endif","","#endif \/\/ TREE_SITTER_{LANG}_H_"],"syntax":"cpp"},{"level":2,"type":"heading","text":"Add it to CodeEditLanguages","anchor":"Add-it-to-CodeEditLanguages"},{"type":"paragraph","inlineContent":[{"text":"In order to add a language to ","type":"text"},{"type":"reference","identifier":"doc:\/\/CodeEditLanguages\/documentation\/CodeEditLanguages","isActive":true},{"type":"text","text":" you need to open the "},{"type":"codeVoice","code":".xcodeproj"},{"type":"text","text":" file located inside "},{"code":"CodeLanguage-Container","type":"codeVoice"},{"type":"text","text":"."}]},{"inlineContent":[{"type":"image","identifier":"xcodeproj-location"}],"type":"paragraph"},{"type":"orderedList","items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Add the "},{"code":"tree-sitter","type":"codeVoice"},{"text":" package you created earlier as a dependency like you would in a regular Xcode project.","type":"text"}]}]},{"content":[{"inlineContent":[{"text":"Then make sure the framework target loads the package module.","type":"text"}],"type":"paragraph"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"Now open the ","type":"text"},{"code":"CodeLanguages_Container.h","type":"codeVoice"},{"text":" header file and add:","type":"text"}]},{"code":["extern TSLanguage *tree_sitter_{lang}();"],"syntax":"cpp","type":"codeListing"},{"name":"Important","style":"important","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Please keep an alphabetical order"}]}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Now create the "},{"code":"xcframework","type":"codeVoice"},{"text":" by running the ","type":"text"},{"code":"build_framework.sh","type":"codeVoice"},{"text":" script from the Package’s root directory.","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"bash","code":["$ .\/build_framework.sh"]},{"name":"Note","style":"note","type":"aside","content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"To run the script, you need to install "},{"code":"jq","type":"codeVoice"},{"text":" by downloading it ","type":"text"},{"identifier":"https:\/\/stedolan.github.io\/jq\/","isActive":true,"type":"reference"},{"type":"text","text":" or with Homebrew using:"}]},{"type":"codeListing","code":["$ brew install jq"],"syntax":"bash"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Check the output of the script. It should say "},{"code":"Done!","type":"codeVoice"},{"type":"text","text":" at the end."},{"text":" ","type":"text"},{"identifier":"build-output","type":"image"}],"type":"paragraph"},{"content":[{"inlineContent":[{"text":"If this does not succeed, try running the script using the ","type":"text"},{"code":"--debug","type":"codeVoice"},{"type":"text","text":" flag to get verbose output:"}],"type":"paragraph"},{"code":["$ .\/build_framework.sh --debug"],"type":"codeListing","syntax":"bash"}],"type":"aside","name":"Tip","style":"tip"}]},{"content":[{"type":"paragraph","inlineContent":[{"text":"You are now done in the Xcode Project and may close it now. Open the Package and continue.","type":"text"}]}]}]},{"level":2,"anchor":"Add-it-to-CodeLanguage","text":"Add it to CodeLanguage","type":"heading"},{"type":"paragraph","inlineContent":[{"type":"text","text":"Now move over to the "},{"code":"Sources\/CodeEditLanguages","type":"codeVoice"},{"text":" folder where 3 files need to be updated.","type":"text"}]},{"anchor":"TreeSitterLanguageswift","level":3,"text":"TreeSitterLanguage.swift","type":"heading"},{"inlineContent":[{"type":"text","text":"Add a case for your language to "},{"isActive":true,"type":"reference","identifier":"doc:\/\/CodeEditLanguages\/documentation\/CodeEditLanguages\/TreeSitterLanguage"},{"type":"text","text":":"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["public enum TreeSitterLanguage: String {","    \/\/ other cases","    case {lang}","}"]},{"type":"heading","level":3,"text":"CodeLanguage.swift","anchor":"CodeLanguageswift"},{"inlineContent":[{"text":"Find the ","type":"text"},{"code":"tsLanguage","type":"codeVoice"},{"text":" computed property and add a ","type":"text"},{"code":"case","type":"codeVoice"},{"text":" to it:","type":"text"}],"type":"paragraph"},{"type":"codeListing","syntax":"swift","code":["private var tsLanguage: UnsafeMutablePointer<TSLanguage>? {","    switch id {","    \/\/ other cases","    case .{lang}:","        return tree_sitter_{lang}()","    }","    \/\/ other cases","}"]},{"type":"paragraph","inlineContent":[{"type":"text","text":"On the bottom of the file add a new "},{"code":"static","type":"codeVoice"},{"text":" constant:","type":"text"}]},{"syntax":"swift","type":"codeListing","code":["static let {lang}: CodeLanguage = .init(","    id: .{lang}, ","    tsName: {lang}, ","    extensions: [...]",")"]},{"style":"important","name":"Important","type":"aside","content":[{"type":"paragraph","