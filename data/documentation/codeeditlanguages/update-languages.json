{"kind":"article","sections":[],"primaryContentSections":[{"kind":"content","content":[{"type":"heading","text":"Overview","anchor":"Overview","level":2},{"type":"paragraph","inlineContent":[{"type":"text","text":"From time to time the "},{"code":"tree-sitter","type":"codeVoice"},{"type":"text","text":" languages need to be updated to their latest version. This is pretty straight forward and can be done in less than 5 minutes."}]},{"anchor":"Update-the-Dependencies","text":"Update the Dependencies","type":"heading","level":2},{"items":[{"content":[{"type":"paragraph","inlineContent":[{"type":"text","text":"Open the "},{"code":"CodeLanguages-Container.xcodeproj","type":"codeVoice"},{"type":"text","text":" which is located inside the "},{"type":"codeVoice","code":".\/CodeLanguages-Container"},{"text":" directory.","type":"text"},{"text":" ","type":"text"},{"type":"image","identifier":"xcodeproj-location"}]}]},{"content":[{"inlineContent":[{"type":"text","text":"Go to "},{"code":"File > Packages > Update to Latest Package Versions","type":"codeVoice"},{"type":"text","text":" and let it resolve the SPM dependencies."}],"type":"paragraph"},{"name":"Note","type":"aside","style":"note","content":[{"inlineContent":[{"type":"text","text":"Depending on your internet connection and Mac hardware this step can take a couple of minutes."}],"type":"paragraph"}]}]},{"content":[{"inlineContent":[{"text":"Close the project","type":"text"}],"type":"paragraph"}]}],"type":"orderedList"},{"style":"tip","name":"Tip","content":[{"type":"paragraph","inlineContent":[{"text":"At this stage you can check if anything changed at all by checking the git status. If ","type":"text"},{"code":"Package.resolved","type":"codeVoice"},{"type":"text","text":" does not appear in the changed files list, you don’t need to proceed."}]},{"syntax":"bash","code":["$ git status"],"type":"codeListing"}],"type":"aside"},{"text":"Update the Framework","anchor":"Update-the-Framework","type":"heading","level":2},{"ite